{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Swift",
      "type": "process",
      "command": "${workspaceFolder}\\run-swift.bat",
      "args": [
        "${file}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}